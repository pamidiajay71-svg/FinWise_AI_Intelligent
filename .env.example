# FinWise AI — Environment Variables

# Supabase (pre-populated in hosted environment)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Claude AI API Key (set as edge function secret, not in client .env)
# Set via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxxxx
# Or:     supabase secrets set CLAUDE_API_KEY=sk-ant-xxxxx

# Google Apps Script Webhook URL (set as edge function secret)
# Set via: supabase secrets set GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxx/exec
